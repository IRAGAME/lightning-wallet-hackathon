# Lightning API Backend Configuration
# Copy to .env and fill in the values from extract_lnd_credentials.sh

# LND Connection (get these from: ./scripts/extract_lnd_credentials.sh)
LND_GRPC_HOST=127.0.0.1:10009
LND_MACAROON_BASE64=YOUR_MACAROON_BASE64_HERE
LND_TLS_CERT_BASE64=YOUR_CERT_BASE64_HERE

# Server
PORT=5003
NODE_ENV=development
